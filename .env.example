# Google Gemini through Vertex AI (authentication uses gcloud ADC, not an API key)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# Personal OpenAI
OPENAI_API_KEY=
OPENAI_PERSONAL_API_KEY=
OPENAI_PERSONAL_DEFAULT_MODEL=gpt-4.1-mini

# Generic OpenAI-compatible provider
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_DEFAULT_MODEL=

# Local OpenAI-compatible provider
# Many local servers ignore the API key, but the OpenAI client still expects a value.
LOCAL_OPENAI_API_KEY=not-needed
LOCAL_OPENAI_BASE_URL=http://localhost:1234/v1
LOCAL_OPENAI_DEFAULT_MODEL=
