Screen.theme-light {
    background: #FAFAF8;
    color: #1C1C1C;
}

Screen.theme-light #chat {
    background: #FAFAF8;
    color: #1C1C1C;
}

Screen.theme-light #model_select {
    background: #EFF8FF;
    color: #102A43;
}

Screen.theme-light #model_header {
    color: #186FAF;
}

Screen.theme-light #model_tree {
    background: #EFF8FF;
    color: #102A43;
}

Screen.theme-light #pending_select {
    background: #FFF7ED;
    color: #2A1A10;
}

Screen.theme-light #pending_header {
    color: #A45A1C;
}

Screen.theme-light #pending_list_pane {
    border: round #C47A3A;
}

Screen.theme-light #pending_diff_scroll {
    border: round #C47A3A;
}

Screen.theme-light #chat_select {
    background: #FFF7ED;
    color: #2A1A10;
}

Screen.theme-light #chat_header {
    color: #A45A1C;
}

Screen.theme-light #chat_list_scroll {
    border: round #C47A3A;
}

Screen.theme-light #chat_detail_scroll {
    border: round #C47A3A;
}

Screen.theme-light #chat_history_scroll {
    border: round #C47A3A;
}

Screen.theme-light #chat_list_scroll,
Screen.theme-light #chat_detail_scroll,
Screen.theme-light #chat_history_scroll,
Screen.theme-light #pending_diff_scroll {
    scrollbar-color: #A45A1C;
    scrollbar-color-hover: #C47A3A;
    scrollbar-color-active: #D9904F;
    scrollbar-corner-color: #FFF7ED;
    scrollbar-background: #FFF1DD;
}

Screen.theme-light.chat-select-mode #input {
    background: #FFF1DD;
    color: #2A1A10;
    border: round #A45A1C;
}

Screen.theme-light.chat-select-mode #input:focus {
    border: heavy #C47A3A;
}

Screen.theme-light.pending-select-mode #input {
    background: #FFF1DD;
    color: #2A1A10;
    border: round #A45A1C;
}

Screen.theme-light.pending-select-mode #input:focus {
    border: heavy #C47A3A;
}

Screen.theme-light #input {
    background: #FFFFFF;
    color: #1C1C1C;
    border: round #A45A1C;
}

Screen.theme-light #input:focus {
    border: heavy #C47A3A;
}

Screen.theme-light.model-select-mode #input {
    background: #DCEEFF;
    color: #102A43;
    border: round #2680C2;
}

Screen.theme-light.model-select-mode #input:focus {
    border: heavy #186FAF;
}

Screen.theme-light #footer_hint {
    background: #E3D7CA;
    color: #2A1A10;
    text-style: bold;
}
