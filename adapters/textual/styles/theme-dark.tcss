Screen.theme-dark {
    background: #121212;
    color: #F5F3EF;
}

Screen.theme-dark #chat {
    background: #121212;
    color: #F5F3EF;
}

Screen.theme-dark #model_select {
    background: #081A2A;
    color: #E8F6FF;
}

Screen.theme-dark #model_header {
    color: #66B8FF;
}

Screen.theme-dark #model_tree {
    background: #081A2A;
    color: #E8F6FF;
}

Screen.theme-dark #pending_select {
    background: #18120D;
    color: #F5F3EF;
}

Screen.theme-dark #pending_header {
    color: #E3A35C;
}

Screen.theme-dark #pending_list_pane {
    border: round #8A5A32;
}

Screen.theme-dark #pending_diff_scroll {
    border: round #8A5A32;
}

Screen.theme-dark #chat_select {
    background: #18120D;
    color: #F5F3EF;
}

Screen.theme-dark #chat_header {
    color: #E3A35C;
}

Screen.theme-dark #chat_list_scroll {
    border: round #8A5A32;
}

Screen.theme-dark #chat_detail_scroll {
    border: round #8A5A32;
}

Screen.theme-dark #chat_history_scroll {
    border: round #8A5A32;
}

Screen.theme-dark #chat_list_scroll,
Screen.theme-dark #chat_detail_scroll,
Screen.theme-dark #chat_history_scroll,
Screen.theme-dark #pending_diff_scroll {
    scrollbar-color: #C47A3A;
    scrollbar-color-hover: #E3A35C;
    scrollbar-color-active: #F0BB7A;
    scrollbar-corner-color: #18120D;
    scrollbar-background: #2A1A10;
}

Screen.theme-dark.chat-select-mode #input {
    background: #2A1A10;
    color: #F5F3EF;
    border: round #C47A3A;
}

Screen.theme-dark.chat-select-mode #input:focus {
    border: heavy #E3A35C;
}

Screen.theme-dark.pending-select-mode #input {
    background: #2A1A10;
    color: #F5F3EF;
    border: round #C47A3A;
}

Screen.theme-dark.pending-select-mode #input:focus {
    border: heavy #E3A35C;
}

Screen.theme-dark #input {
    background: #1E1A17;
    color: #F5F3EF;
    border: round #C47A3A;
}

Screen.theme-dark #input:focus {
    border: heavy #D9904F;
}

Screen.theme-dark.model-select-mode #input {
    background: #062B49;
    color: #E8F6FF;
    border: round #339CFF;
}

Screen.theme-dark.model-select-mode #input:focus {
    border: heavy #66B8FF;
}

Screen.theme-dark #footer_hint {
    background: #1E1A17;
    color: #F5F3EF;
    text-style: bold;
}
