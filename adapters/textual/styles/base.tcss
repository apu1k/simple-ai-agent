Screen {
    layout: vertical;
}

.hidden {
    display: none;
}

#chat_scroll {
    height: 1fr;
    width: 100%;
    scrollbar-size: 0 0;
}

#chat {
    height: auto;
    width: 100%;
    padding: 1 2;
}

#model_select {
    height: 1fr;
    width: 100%;
    padding: 1 2;
}

#model_header {
    height: auto;
    width: 100%;
    padding: 0 0 1 0;
    text-style: bold;
}

#model_tree {
    height: 1fr;
    width: 100%;
}

#input {
    height: 3;
}

#footer_hint {
    height: 1;
    padding: 0 1;
}
