Screen {
    layout: vertical;
}

#top_status {
    dock: top;
    height: 1;
    layout: horizontal;
    background: $surface;
    color: $text-muted;
}

#status_cwd,
#status_model,
#status_edits {
    height: 1;
    width: 1fr;
    padding: 0 1;
}

#status_model {
    text-align: center;
}

#status_edits {
    text-align: right;
}

.hidden {
    display: none;
}

#chat_scroll {
    height: 1fr;
    width: 100%;
    scrollbar-size: 0 0;
}

#chat {
    height: auto;
    width: 100%;
    padding: 1 2;
}

#model_select {
    height: 1fr;
    width: 100%;
    padding: 1 2;
}

#model_header {
    height: auto;
    width: 100%;
    padding: 0 0 1 0;
    text-style: bold;
}

#model_tree {
    height: 1fr;
    width: 100%;
}

#pending_select {
    height: 1fr;
    width: 100%;
    padding: 1 2;
}

#pending_header {
    height: auto;
    width: 100%;
    padding: 0 0 1 0;
    text-style: bold;
}

#pending_body {
    layout: horizontal;
    height: 1fr;
    width: 100%;
}

#pending_list_pane {
    height: 100%;
    width: 32%;
    padding: 0 1 0 0;
}

#pending_list {
    height: 100%;
    width: 100%;
}

#pending_diff_scroll {
    height: 100%;
    width: 68%;
}

#pending_diff {
    height: auto;
    width: auto;
    padding: 0 0 0 1;
}

#chat_select {
    height: 1fr;
    width: 100%;
    padding: 1 2;
}

#chat_header {
    height: auto;
    width: 100%;
    padding: 0 0 1 0;
    text-style: bold;
}

#chat_body {
    layout: horizontal;
    height: 1fr;
    width: 100%;
}

#chat_list_scroll {
    height: 100%;
    width: 15%;
}

#chat_list_pane {
    height: auto;
    width: 100%;
    padding: 0 1 0 0;
}

#chat_list {
    height: auto;
    width: 100%;
}

#chat_detail_scroll {
    height: 100%;
    width: 30%;
}

#chat_detail {
    height: auto;
    width: auto;
    padding: 0 1;
}

#chat_history_scroll {
    height: 100%;
    width: 55%;
}

#chat_history {
    height: auto;
    width: auto;
    padding: 0 0 0 1;
}

#input {
    height: 3;
}

#footer_hint {
    height: 1;
    padding: 0 1;
}
